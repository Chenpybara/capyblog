---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const latest = sorted.slice(0, 15);
---


<Layout>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-gray-800">
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-950/80 via-gray-950 to-gray-950" />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-indigo-900/30 via-transparent to-transparent" />
    <div class="relative mx-auto max-w-5xl px-6 py-12 md:py-16">
      <div class="max-w-2xl">
        <span class="inline-block rounded-full bg-indigo-500/10 px-4 py-1.5 text-sm font-medium text-indigo-400 mb-4">
          Welcome to Capyblog
        </span>
        <h1 class="text-4xl font-bold tracking-tight leading-tight md:text-5xl">
          My channel features <span class="text-indigo-400">sports content</span> and entertainment.
        </h1>
      </div>
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="mx-auto max-w-5xl px-6 py-20">
    <div class="flex items-center justify-between mb-10">
      <div>
        <h2 class="text-2xl font-bold">Latest Posts</h2>
      </div>
      <a href="/blog" class="text-sm font-medium text-indigo-400 hover:underline">
        View all &rarr;
      </a>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {latest.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <!-- Stats / CTA -->
  <section class="border-t border-gray-800 bg-gray-900/50">
    <div class="mx-auto max-w-5xl px-6 py-20">
      <div class="grid gap-8 text-center sm:grid-cols-3">
        <div>
          <div class="text-3xl font-bold text-indigo-400">2</div>
          <div class="mt-1 text-sm text-gray-500">Blog Posts</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-indigo-400">52</div>
          <div class="mt-1 text-sm text-gray-500">Videos This Year</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-indigo-400">2.4K</div>
          <div class="mt-1 text-sm text-gray-500">Visitors</div>
        </div>
      </div>
    </div>
  </section>
</Layout>
