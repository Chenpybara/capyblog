---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
];
---

<header class="sticky top-0 z-50 border-b border-gray-800 bg-gray-950/80 backdrop-blur">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="/" class="text-xl font-bold tracking-tight">
      <span class="text-indigo-400">Capy</span><span class="text-gray-100">blog</span>
    </a>
    <ul class="flex gap-8 text-sm font-medium text-gray-400">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="transition-colors hover:text-indigo-400"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
